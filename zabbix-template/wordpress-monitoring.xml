<?xml version="1.0" encoding="UTF-8"?>
<!--
    WP Zabbix Monitor — Zabbix Template
    Version:  1.0.0
    Requires: Zabbix 6.0 or later

    This template supports two collection modes:
      1. HTTP Agent (pull): Zabbix polls the WordPress REST API endpoint.
         Configure {$WP_URL} and {$WP_API_TOKEN} macros on the host.
      2. Zabbix Trapper (push): WordPress pushes data via the Zabbix Sender protocol.
         Enable "Push Metrics" in the plugin settings.

    Import: Configuration → Templates → Import
-->
<zabbix_export>
    <version>6.0</version>
    <date>2024-01-01T00:00:00Z</date>

    <template_groups>
        <template_group>
            <uuid>a571c0d144b14fd4a87a9d9b2aa9fcd6</uuid>
            <name>WordPress</name>
        </template_group>
    </template_groups>

    <templates>
        <template>
            <uuid>7e5a4e1b3c2d4f6a8b0c2e4f6a8b0c2e</uuid>
            <template>WordPress by WP Zabbix Monitor</template>
            <name>WordPress by WP Zabbix Monitor</name>
            <description>
                Monitors a WordPress installation via the WP Zabbix Monitor plugin.
                Supports both HTTP Agent (pull) and Zabbix Sender (push) modes.

                Required host macros:
                  {$WP_URL}       — WordPress site URL, e.g. https://example.com
                  {$WP_API_TOKEN} — API token from the plugin settings page
            </description>
            <groups>
                <group>
                    <name>WordPress</name>
                </group>
            </groups>

            <!-- ─── Macros ──────────────────────────────────────────────────── -->
            <macros>
                <macro>
                    <macro>{$WP_URL}</macro>
                    <value>https://example.com</value>
                    <description>WordPress site URL (no trailing slash)</description>
                </macro>
                <macro>
                    <macro>{$WP_API_TOKEN}</macro>
                    <value></value>
                    <type>SECRET_TEXT</type>
                    <description>API token from WP Zabbix Monitor plugin settings</description>
                </macro>
                <macro>
                    <macro>{$WP_LOAD_TIME_WARN}</macro>
                    <value>1000</value>
                    <description>Page load time warning threshold (ms)</description>
                </macro>
                <macro>
                    <macro>{$WP_LOAD_TIME_HIGH}</macro>
                    <value>3000</value>
                    <description>Page load time critical threshold (ms)</description>
                </macro>
                <macro>
                    <macro>{$WP_MEMORY_WARN}</macro>
                    <value>80</value>
                    <description>Memory usage warning threshold (% of limit)</description>
                </macro>
                <macro>
                    <macro>{$WP_DB_QUERY_WARN}</macro>
                    <value>100</value>
                    <description>DB query count warning threshold per request</description>
                </macro>
                <macro>
                    <macro>{$WP_DISK_WARN}</macro>
                    <value>80</value>
                    <description>Disk usage warning threshold (%)</description>
                </macro>
                <macro>
                    <macro>{$WP_DISK_HIGH}</macro>
                    <value>90</value>
                    <description>Disk usage critical threshold (%)</description>
                </macro>
                <macro>
                    <macro>{$WP_PLUGIN_UPDATES_WARN}</macro>
                    <value>1</value>
                    <description>Trigger when this many plugin updates are available</description>
                </macro>
                <macro>
                    <macro>{$WP_OVERDUE_CRON_WARN}</macro>
                    <value>3</value>
                    <description>Trigger when this many cron events are overdue</description>
                </macro>
            </macros>

            <!-- ─── Items ───────────────────────────────────────────────────── -->
            <items>

                <!-- Master item: fetch full JSON payload -->
                <item>
                    <uuid>a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6</uuid>
                    <name>WordPress: Raw metrics JSON</name>
                    <type>HTTP_AGENT</type>
                    <key>wordpress.metrics.raw</key>
                    <delay>60s</delay>
                    <history>1h</history>
                    <trends>0</trends>
                    <value_type>TEXT</value_type>
                    <url>{$WP_URL}/wp-json/wpzm/v1/metrics</url>
                    <headers>
                        <header>
                            <name>Authorization</name>
                            <value>Bearer {$WP_API_TOKEN}</value>
                        </header>
                    </headers>
                    <status_codes>200</status_codes>
                    <follow_redirects>YES</follow_redirects>
                    <retrieve_mode>BODY</retrieve_mode>
                    <description>Master HTTP Agent item. All other items depend on this via JSONPath preprocessing.</description>
                    <tags>
                        <tag><tag>component</tag><value>wordpress</value></tag>
                        <tag><tag>group</tag><value>master</value></tag>
                    </tags>
                </item>

                <!-- Ping / availability -->
                <item>
                    <uuid>b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6</uuid>
                    <name>WordPress: Site availability</name>
                    <type>HTTP_AGENT</type>
                    <key>wordpress.ping</key>
                    <delay>30s</delay>
                    <value_type>UNSIGNED</value_type>
                    <url>{$WP_URL}/wp-json/wpzm/v1/ping</url>
                    <status_codes>200</status_codes>
                    <follow_redirects>YES</follow_redirects>
                    <retrieve_mode>BODY</retrieve_mode>
                    <preprocessing>
                        <step>
                            <type>JSONPATH</type>
                            <parameters>
                                <parameter>$.timestamp</parameter>
                            </parameters>
                            <error_handler>CUSTOM_VALUE</error_handler>
                            <error_handler_params>0</error_handler_params>
                        </step>
                        <step>
                            <type>BOOL_TO_DECIMAL</type>
                            <parameters><parameter/></parameters>
                        </step>
                    </preprocessing>
                    <valuemap>
                        <name>Service state</name>
                    </valuemap>
                    <description>1 = site is reachable and plugin is active, 0 = unreachable.</description>
                    <tags>
                        <tag><tag>component</tag><value>availability</value></tag>
                    </tags>
                </item>

