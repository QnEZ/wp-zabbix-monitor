            <!-- ─── Triggers ────────────────────────────────────────────────── -->
            <triggers>

                <trigger>
                    <uuid>t1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6</uuid>
                    <expression>last(/WordPress by WP Zabbix Monitor/wordpress.ping)=0</expression>
                    <name>WordPress: Site is unreachable</name>
                    <priority>HIGH</priority>
                    <description>The WordPress REST API ping endpoint returned an error or the site is down.</description>
                    <tags>
                        <tag><tag>scope</tag><value>availability</value></tag>
                    </tags>
                </trigger>

                <trigger>
                    <uuid>t2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7</uuid>
                    <expression>avg(/WordPress by WP Zabbix Monitor/wordpress.performance.load_time_ms,5m)>{$WP_LOAD_TIME_HIGH}</expression>
                    <name>WordPress: Page load time is critically high (avg &gt; {$WP_LOAD_TIME_HIGH}ms)</name>
                    <priority>HIGH</priority>
                    <description>Average page load time over 5 minutes exceeds the critical threshold.</description>
                    <tags>
                        <tag><tag>scope</tag><value>performance</value></tag>
                    </tags>
                </trigger>

                <trigger>
                    <uuid>t3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8</uuid>
                    <expression>avg(/WordPress by WP Zabbix Monitor/wordpress.performance.load_time_ms,5m)>{$WP_LOAD_TIME_WARN}</expression>
                    <name>WordPress: Page load time is elevated (avg &gt; {$WP_LOAD_TIME_WARN}ms)</name>
                    <priority>WARNING</priority>
                    <dependencies>
                        <dependency>
                            <name>WordPress: Page load time is critically high (avg &gt; {$WP_LOAD_TIME_HIGH}ms)</name>
                            <expression>avg(/WordPress by WP Zabbix Monitor/wordpress.performance.load_time_ms,5m)>{$WP_LOAD_TIME_HIGH}</expression>
